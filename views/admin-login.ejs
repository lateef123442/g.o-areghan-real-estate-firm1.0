<!DOCTYPE html>
<html lang="en">
<head>
  <base href="/">
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login - G.O AREGHAN REAL ESTATE FIRM and Consultant</title>
  <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
  <style>
    *, *::before, *::after {
      box-sizing: border-box;
    }
    body {
      margin: 0;
      font-family: 'Plus Jakarta Sans', 'Inter', system-ui, -apple-system, sans-serif;
      background: radial-gradient(circle at 50% 50%, #1e293b 0%, #0f172a 100%);
      color: #f8fafc;
      display: flex;
      justify-content: center;
      align-items: center;
      height: 100vh;
      overflow: hidden;
    }
    .login-container {
      background: rgba(30, 41, 59, 0.45);
      backdrop-filter: blur(16px);
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 16px;
      box-shadow: 0 20px 50px rgba(0, 0, 0, 0.3);
      padding: 48px 40px;
      width: 100%;
      max-width: 420px;
      animation: fadeIn 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }
    @keyframes fadeIn {
      from { transform: translateY(20px); opacity: 0; }
      to { transform: translateY(0); opacity: 1; }
    }
    .login-container p.title-accent {
      text-align: center;
      margin-bottom: 8px;
      color: #d4af37;
      font-size: 0.75rem;
      letter-spacing: 0.15em;
      font-weight: 700;
      text-transform: uppercase;
    }
    .login-container h1 {
      text-align: center;
      margin: 0 0 32px 0;
      font-size: 1.75rem;
      font-weight: 800;
      letter-spacing: -0.02em;
      color: #ffffff;
    }
    hr {
      border: 0;
      height: 1px;
      background: rgba(255, 255, 255, 0.1);
      margin: 16px 0;
    }
    .form-group {
      margin-bottom: 24px;
      position: relative;
    }
    label {
      display: block;
      margin-bottom: 8px;
      font-weight: 600;
      font-size: 0.85rem;
      color: #cbd5e1;
      letter-spacing: 0.01em;
    }
    input[type="email"],
    input[type="password"], input[type="text"] {
      width: 100%;
      padding: 14px 44px 14px 16px;
      background: rgba(15, 23, 42, 0.6);
      border: 1.5px solid rgba(255, 255, 255, 0.1);
      border-radius: 10px;
      font-size: 0.95rem;
      color: #ffffff;
      transition: all 0.3s ease;
    }
    input::placeholder {
      color: #64748b;
    }
    input:focus {
      border-color: #d4af37;
      box-shadow: 0 0 0 3px rgba(212, 175, 55, 0.2);
      background: rgba(15, 23, 42, 0.8);
      outline: none;
    }
    button[type="submit"] {
      width: 100%;
      padding: 14px;
      background: linear-gradient(135deg, #d4af37 0%, #b38a38 100%);
      color: #0f172a;
      font-weight: 700;
      font-size: 0.95rem;
      letter-spacing: 0.02em;
      border: none;
      border-radius: 10px;
      cursor: pointer;
      box-shadow: 0 4px 15px rgba(212, 175, 55, 0.2);
      transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    }
    button[type="submit"]:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 25px rgba(212, 175, 55, 0.35);
      background: linear-gradient(135deg, #e5c158 0%, #c5a880 100%);
    }
    button[type="submit"]:active {
      transform: translateY(0);
    }
    .footer-links {
      text-align: center;
      margin-top: 28px;
      font-size: 0.85rem;
      color: #94a3b8;
    }
    .footer-links a {
      color: #d4af37;
      text-decoration: none;
      font-weight: 600;
      transition: color 0.3s ease;
    }
    .footer-links a:hover {
      color: #cbd5e1;
    }
    .show-password {
      position: absolute;
      right: 12px;
      top: 38px;
      cursor: pointer;
      color: #94a3b8;
      font-size: 20px;
      transition: color 0.3s ease;
      user-select: none;
      background: transparent;
      border: none;
      padding: 4px;
    }
    .show-password:hover {
      color: #d4af37;
    }
  </style>
</head>
<body>
  <div class="login-container">
    <p class="title-accent">G.O AREGHAN REAL ESTATE FIRM AND CONSULTANT</p>
    <hr>
    <h1>Login</h1>
    <form action="signin" method="post">
      <div class="form-group">
        <label for="email">Email</label>
        <input type="email" id="email" name="email" required placeholder="Enter your email">
      </div>
      <div class="form-group">
        <label for="password">Password</label>
        <input type="password" id="password" name="password" required placeholder="Enter your password">
        <span class="material-icons show-password" id="togglePassword" onclick="togglePasswordVisibility()">visibility</span>
      </div>
      <button type="submit">Login</button>
    </form>
    <div class="footer-links">
      <a href="/forgot-password.html">Forgot Password?</a> | 
      <a href="/register.html">Create an Account</a>
    </div>
  </div>

  <script>
    function togglePasswordVisibility() {
      const passwordInput = document.getElementById('password');
      const toggleIcon = document.getElementById('togglePassword');
      if (passwordInput.type === 'password') {
        passwordInput.type = 'text';
        toggleIcon.textContent = 'visibility_off'; // Change icon to 'visibility_off'
      } else {
        passwordInput.type = 'password';
        toggleIcon.textContent = 'visibility'; // Change icon back to 'visibility'
      }
    }
  </script>
</body>
</html>

